# Environment: development | staging | production | test
NODE_ENV=development

# Port the NestJS application listens on
PORT=3000

# PostgreSQL connection string (used by Prisma).
# Host-side (running Prisma/dev outside Docker) connects to the compose
# Postgres on port 5433. Inside Docker Compose the backend overrides this to
# reach the postgres service on its internal port 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/quiz_platform?schema=public"

# Origin allowed to call this API (the frontend's URL)
CORS_ORIGIN=http://localhost:5173
