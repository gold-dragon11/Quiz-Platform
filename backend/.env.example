# Environment: development | staging | production | test
NODE_ENV=development

# Port the NestJS application listens on
PORT=3000

# PostgreSQL connection string (used by Prisma).
# Host-side (running Prisma/dev outside Docker) connects to the compose
# Postgres on port 5433. Inside Docker Compose the backend overrides this to
# reach the postgres service on its internal port 5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/quiz_platform?schema=public"

# Origin allowed to call this API (the frontend's URL)
CORS_ORIGIN=http://localhost:5173

# --- Authentication ---------------------------------------------------------
# Signing secrets for JWT access and refresh tokens. They must be long, random,
# and different from each other so that leaking one never compromises the other
# (docs/06-backend/authentication.md §6-7, docs/06-backend/security.md §17).
#
# Generate each with:  openssl rand -base64 48
# Minimum accepted length: 32 characters. Never commit real secrets.
JWT_ACCESS_SECRET=replace-me-with-a-long-random-access-secret-min-32-chars
JWT_REFRESH_SECRET=replace-me-with-a-long-random-refresh-secret-min-32-chars

# Token lifetimes in zeit/ms format. Access tokens are short-lived, refresh
# tokens long-lived (docs/06-backend/authentication.md §7).
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Email verification -----------------------------------------------------
# Signing secret for email verification tokens. Must be long, random, and
# different from both JWT secrets (docs/06-backend/authentication.md §8).
# Generate with:  openssl rand -base64 48   (minimum 32 characters)
EMAIL_VERIFICATION_SECRET=replace-me-with-a-long-random-verification-secret-min-32-chars
EMAIL_VERIFICATION_EXPIRES_IN=24h

# --- Password reset ---------------------------------------------------------
# Signing secret for password reset tokens. Must be long, random, and
# different from every other secret (docs/06-backend/authentication.md §9).
# Generate with:  openssl rand -base64 48   (minimum 32 characters)
PASSWORD_RESET_SECRET=replace-me-with-a-long-random-password-reset-secret-min-32
PASSWORD_RESET_EXPIRES_IN=1h

# Base URL of the frontend, used to build the links sent in emails
# (e.g. the /verify-email page).
FRONTEND_URL=http://localhost:5173
